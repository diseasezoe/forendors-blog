<div class="newsletter">
  <div class="newsletter-icon">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
  </div>
  <h2>Nové články do schránky</h2>
  <p>Přihlaste se k odběru a nepropásněte tipy, rozhovory a novinky ze světa tvorby.</p>
  <div class="qndTrigger" data-key="52e81e94eff9ccad5d1c79195dcffcb8" data-form-html-class="" data-static="true">&nbsp;</div>
  <div class="newsletter-msg" id="newsletterMsg" style="display:none;"></div>
</div>
<script is:inline>
  (function() {
    function loadQuanda() {
      if (document.querySelector('.qndTrigger form')) return;
      var s = document.createElement('script');
      s.src = 'https://webform.onquanda.com/static/js/webform/embedded.min.js';
      s.onload = function() {
        var _qndReady = setInterval(function() {
          var input = document.querySelector('.qndTrigger input:not([type="submit"]):not([type="hidden"])');
          if (!input) return;
          clearInterval(_qndReady);

          input.placeholder = 'Zadejte svůj e-mail';
          input.setAttribute('type', 'email');

          var form = document.querySelector('.qndTrigger form');
          if (form) {
            form.addEventListener('submit', function(e) {
              var msg = document.getElementById('newsletterMsg');
              var val = input.value.trim();
              if (!val || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
                e.preventDefault();
                e.stopPropagation();
                input.style.borderColor = 'var(--accent)';
                if (msg) {
                  msg.textContent = 'Zadejte platnou e-mailovou adresu.';
                  msg.style.display = 'block';
                  msg.style.color = 'var(--accent)';
                }
                return false;
              }
              input.style.borderColor = '';
              if (msg) {
                msg.textContent = 'Odesílám...';
                msg.style.display = 'block';
                msg.style.color = 'var(--text-muted)';
              }
            }, true);
          }

          // Watch for success (Quanda replaces form content)
          var observer = new MutationObserver(function() {
            var msg = document.getElementById('newsletterMsg');
            var formStillThere = document.querySelector('.qndTrigger form');
            if (!formStillThere && msg) {
              msg.textContent = 'Díky za přihlášení!';
              msg.style.display = 'block';
              msg.style.color = '#10b981';
              observer.disconnect();
            }
          });
          var trigger = document.querySelector('.qndTrigger');
          if (trigger) observer.observe(trigger, { childList: true, subtree: true });
        }, 300);
        setTimeout(function() { clearInterval(_qndReady); }, 10000);
      };
      document.body.appendChild(s);
    }
    if (document.readyState === 'complete') { loadQuanda(); }
    else { window.addEventListener('load', loadQuanda); }
  })();
</script>
