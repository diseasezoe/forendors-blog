<div class="newsletter">
  <div class="newsletter-icon">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
  </div>
  <h2>Nové články do schránky</h2>
  <p>Přihlaste se k odběru a nepropásněte tipy, rozhovory a novinky ze světa tvorby.</p>
  <div class="newsletter-form-wrap">
    <form class="newsletter-form" id="newsletterForm" novalidate>
      <input type="email" id="newsletterEmail" placeholder="Zadejte svůj e-mail" required autocomplete="email">
      <button type="submit">Přihlásit</button>
    </form>
    <div id="newsletterMsg" class="newsletter-msg" style="display:none;"></div>
  </div>
  <iframe name="newsletterTarget" id="newsletterIframe" style="display:none;" tabindex="-1"></iframe>
</div>
<script is:inline>
  (function() {
    var form = document.getElementById('newsletterForm');
    var input = document.getElementById('newsletterEmail');
    var msgEl = document.getElementById('newsletterMsg');
    var btn = form.querySelector('button');
    var iframe = document.getElementById('newsletterIframe');
    var QND_URL = 'https://webform.onquanda.com/webform/52e81e94eff9ccad5d1c79195dcffcb8/';

    function showMsg(text, isError) {
      msgEl.textContent = text;
      msgEl.style.display = 'block';
      msgEl.style.color = isError ? '#e74c3c' : 'var(--accent)';
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      msgEl.style.display = 'none';

      var email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        input.style.borderColor = '#e74c3c';
        showMsg('Zadejte platnou e-mailovou adresu.', true);
        return;
      }
      input.style.borderColor = '';
      btn.disabled = true;
      btn.textContent = 'Odesílám...';

      // Create a hidden form that submits to Quanda via iframe (bypasses CORS)
      var hiddenForm = document.createElement('form');
      hiddenForm.method = 'POST';
      hiddenForm.action = QND_URL;
      hiddenForm.target = 'newsletterTarget';
      hiddenForm.style.display = 'none';

      var fields = {
        'contact-email': email,
        'check': '',
        'check_id': '',
        'parent_url': window.location.href
      };
      for (var name in fields) {
        var inp = document.createElement('input');
        inp.type = 'hidden';
        inp.name = name;
        inp.value = fields[name];
        hiddenForm.appendChild(inp);
      }

      document.body.appendChild(hiddenForm);

      // Listen for iframe load (indicates form was submitted)
      var submitted = false;
      iframe.onload = function() {
        if (!submitted) return;
        // Form submitted successfully
        form.style.display = 'none';
        showMsg('Děkujeme za přihlášení! Potvrzení najdete ve svém e-mailu.', false);
        document.body.removeChild(hiddenForm);
      };

      submitted = true;
      hiddenForm.submit();

      // Fallback timeout in case iframe onload doesn't fire
      setTimeout(function() {
        if (btn.disabled && form.style.display !== 'none') {
          form.style.display = 'none';
          showMsg('Děkujeme za přihlášení! Potvrzení najdete ve svém e-mailu.', false);
        }
        try { document.body.removeChild(hiddenForm); } catch(e) {}
      }, 4000);
    });
  })();
</script>
