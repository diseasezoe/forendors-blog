---
interface Props {
  title?: string;
  subtitle?: string;
  showSearch?: boolean;
}

const { title = 'Tipy pro tvůrce', subtitle = 'Rady, rozhovory a novinky ze světa tvorby obsahu a jeho monetizace.', showSearch = true } = Astro.props;
---
<section class="hero">
  <div class="hero-label">Blog</div>
  <h1>{title}</h1>
  <p>{subtitle}</p>
  {showSearch && (
    <div class="search-wrap">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="searchInput" placeholder="Hledat články...">
    </div>
  )}
</section>
