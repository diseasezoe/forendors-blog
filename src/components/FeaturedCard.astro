---
import { getCategoryInfo } from '../lib/categories';
import { formatDate } from '../lib/dates';

interface Props {
  slug: string;
  title: string;
  excerpt: string;
  date: Date;
  category: string;
  image?: string;
}

const { slug, title, excerpt, date, category, image } = Astro.props;
const cat = getCategoryInfo(category);
---
<a class="featured" href={`/${slug}`} style="text-decoration:none; color:inherit;">
  <div class="featured-img" style={image ? '' : undefined}>
    {image ? (
      <img src={image} alt={title}>
    ) : (
      <span>[ Obrázek článku ]</span>
    )}
  </div>
  <div class="featured-body">
    <div class="featured-meta">
      <span class="featured-cat">{cat.label}</span>
      <span class="featured-date">{formatDate(date)}</span>
    </div>
    <h2>{title}</h2>
    <p class="featured-excerpt">{excerpt}</p>
    <span class="read-more">Číst dál <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
  </div>
</a>
